{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaCompressor",
  "version": "../package.json",
  "identifier": "io.github.ben870217.media-compressor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MediaCompressor",
        "width": 1200,
        "height": 820,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./WebView2FixedRuntime"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
